# Polymarket Arbitrage Bot Environment Variables

# Execution Mode
ENVIRONMENT=local

# API Authentication (Required for Live Trading)
POLYMARKET_API_KEY=your_api_key_here
POLYMARKET_API_SECRET=your_api_secret_here
POLYMARKET_API_PASSPHRASE=your_api_passphrase_here

# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/polymarket_arb
REDIS_URL=redis://localhost:6379/0

# Capital
STARTING_CAPITAL=1000.0
