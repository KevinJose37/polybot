# ============================================================
# Polymarket Market Maker Bot — Environment Configuration
# ============================================================

# ── Polymarket Credentials ──────────────────────────────────
PRIVATE_KEY=0x...
FUNDER_ADDRESS=0x...
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# ── Trading Mode ────────────────────────────────────────────
PAPER_TRADING=True
INITIAL_CAPITAL=25.0

# ── Spread Parameters ──────────────────────────────────────
MIN_HALF_SPREAD_BPS=30
SPREAD_VOLATILITY_MULTIPLIER=2.0
SKEW_SENSITIVITY=1.0

# ── Inventory Limits ───────────────────────────────────────
MAX_INVENTORY_PER_MARKET=100
SOFT_INVENTORY_PCT=0.60
HARD_INVENTORY_PCT=0.85

# ── Toxicity Detection ─────────────────────────────────────
TOXICITY_WINDOW_TRADES=20
TOXICITY_THRESHOLD=0.70
DEFENSIVE_SPREAD_MULTIPLIER=3.0

# ── Quote Management ───────────────────────────────────────
MAX_QUOTE_AGE_MS=5000
REPRICE_THRESHOLD_BPS=10
EMERGENCY_REPRICE_BPS=50
MIN_TAU_TO_QUOTE=120

# ── Risk Limits ─────────────────────────────────────────────
DAILY_LOSS_LIMIT=0.20
MAX_NET_TOTAL_INVENTORY=500

# ── Feed Configuration ──────────────────────────────────────
BINANCE_WS_URL=wss://stream.binance.com:9443/ws
STALE_FEED_THRESHOLD_MS=500

# ── Logging ─────────────────────────────────────────────────
LOG_LEVEL=INFO
